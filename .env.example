# Default base URL for the BlueMonk Integration API the demo storefront targets.
# Users can override per-session in the setup screen — this is just the prefilled value.
# Examples:
#   - local dev:  http://localhost:8080
#   - staging:    https://api-staging.bluemonk.example.com
#   - production: https://api.bluemonk.example.com
VITE_INTEGRATION_API_BASE_URL=http://localhost:8080
